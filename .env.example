APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Public Shadow Syndicate site host (production). Leave empty on localhost.
# MAIN_SITE_DOMAIN=luntian.com.au
# MAIN_SITE_URL=https://luntian.com.au

# Tournament X app (login + tournament management) on its own subdomain.
# TOURNAMENTX_DOMAIN=tournamentx.luntian.com.au
# TOURNAMENTX_URL=https://tournamentx.luntian.com.au

# Share login session across *.luntian.com.au (production only).
# SESSION_DOMAIN=.luntian.com.au

# Default credentials when provisioning Shadow Syndicate member accounts (php artisan members:provision-accounts)
# MEMBER_EMAIL_DOMAIN=shadowsyndicate.com
# MEMBER_DEFAULT_PASSWORD=ShadowSyndicate2026!

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Hostinger Git deploy wipes storage/app/public (only .gitignore was in Git). Use a persistent folder:
# 1) File Manager or SSH: create uploads next to your Laravel root (NOT committed to Git)
# 2) cp -a storage/app/public/* uploads/
# 3) On live .env (required):
# PUBLIC_STORAGE_PATH=/home/u922250757/domains/shadowsyndicate.nvsnworks.com/uploads
# 4) php artisan config:clear
# 5) FILESYSTEM_DISK=local  (payment QR/proof stay private; member/blog images use disk public in code)
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
